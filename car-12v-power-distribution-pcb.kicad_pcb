(kicad_pcb (version 20211014) (generator "pcbnew")
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (stackup
      (layer "F.SilkS" (type "Top Silk Screen"))
      (layer "F.Paste" (type "Top Solder Paste"))
      (layer "F.Mask" (type "Top Solder Mask"))
      (layer "F.Cu" (type "copper"))
      (layer "dielectric" (type "core") (thickness 1.6) (material "FR4") (epsilon_r 4.3))
      (layer "B.Cu" (type "copper"))
      (layer "B.Mask" (type "Bottom Solder Mask"))
      (layer "B.Paste" (type "Bottom Solder Paste"))
      (layer "B.SilkS" (type "Bottom Silk Screen"))
    )
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (svguseinch false)
      (svgprecision 6)
      (excludeedgelayer true)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
      (plotreference true)
      (plotvalue true)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk false)
      (outputformat 1)
      (mirror false)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "+12V_BATT")
  (net 3 "+12V_ACC")

  (footprint "PicoSpoX:PicoSpoX_1x02_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "1e3d74c0-e2a2-4ef7-97bc-4ac518508f32")
    (at 40 40)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x02_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "252ea7b0-2563-4823-9b54-49aeda4e390c")
    (at 40 70)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x03_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "96b5de77-f99a-4d94-91d0-96109e1a9ef5")
    (at 110 30)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "3" smd rect (at 6 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x03_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "20f09713-ec7d-4896-b606-52ae38337373")
    (at 110 60)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "3" smd rect (at 6 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x03_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "88fbdd0e-48dc-458e-9dab-dcc095ff2f1b")
    (at 110 90)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "3" smd rect (at 6 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x03_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "5d3439f4-d049-4de6-9566-f8d7a12f3262")
    (at 110 120)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "3" smd rect (at 6 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (footprint "PicoSpoX:PicoSpoX_1x03_P3.00mm_SMD" (layer "F.Cu")
    (tedit 0) (tstamp "f046f22f-2d79-4173-96d9-001e5c82607c")
    (at 110 150)
    (pad "1" smd rect (at 0 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2))
    (pad "2" smd rect (at 3 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3))
    (pad "3" smd rect (at 6 0) (size 1.8 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1))
  )

  (gr_rect (start 20 15) (end 140 175) (layer "Edge.Cuts") (width 0.05))

  (segment (start 40 40) (end 110 30) (width 1.2) (layer "F.Cu") (net 2))
  (segment (start 40 40) (end 110 60) (width 1.2) (layer "F.Cu") (net 2))
  (segment (start 40 40) (end 110 90) (width 1.2) (layer "F.Cu") (net 2))
  (segment (start 40 40) (end 110 120) (width 1.2) (layer "F.Cu") (net 2))
  (segment (start 40 40) (end 110 150) (width 1.2) (layer "F.Cu") (net 2))

  (segment (start 40 70) (end 113 30) (width 1.2) (layer "F.Cu") (net 3))
  (segment (start 40 70) (end 113 60) (width 1.2) (layer "F.Cu") (net 3))
  (segment (start 40 70) (end 113 90) (width 1.2) (layer "F.Cu") (net 3))
  (segment (start 40 70) (end 113 120) (width 1.2) (layer "F.Cu") (net 3))
  (segment (start 40 70) (end 113 150) (width 1.2) (layer "F.Cu") (net 3))

  (segment (start 43 40) (end 43 70) (width 1.2) (layer "F.Cu") (net 1))
  (segment (start 43 40) (end 116 30) (width 1.2) (layer "F.Cu") (net 1))
  (segment (start 43 40) (end 116 60) (width 1.2) (layer "F.Cu") (net 1))
  (segment (start 43 40) (end 116 90) (width 1.2) (layer "F.Cu") (net 1))
  (segment (start 43 40) (end 116 120) (width 1.2) (layer "F.Cu") (net 1))
  (segment (start 43 40) (end 116 150) (width 1.2) (layer "F.Cu") (net 1))
)
