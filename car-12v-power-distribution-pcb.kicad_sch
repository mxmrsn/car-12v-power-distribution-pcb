  (text "12v -> led has ~ 2.7v drop -> we want 20mA\nso that's 12-2.7=9.3v -> V = IR; \nR = V/I = 9.3V/.02 = 465 ~= 500"
    (at 143.51 100.33 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
